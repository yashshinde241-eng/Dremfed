*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# VS Code
.vscode/
*.code-workspace

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db
desktop.ini

# Streamlit
.streamlit/secrets.toml

# Logs
*.log
.env